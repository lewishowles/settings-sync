# Copy this file to .env and customize for your setup.

# GitHub Configuration

# Your GitHub username, used for gist references
GITHUB_USERNAME=your-github-username

# 1Password Configuration

# Path to your GitHub personal access token in 1Password
# Format: op://vault-name/item-name/field-name
# The token must have the "gist" scope
OP_TOKEN_REFERENCE=op://your-vault/GitHub Gist/credential

# Gist IDs

# GitHub Gist ID for VSCode snippets
# Get this from: https://gist.github.com/your-username/GIST_ID
GIST_ID_SNIPPETS=your-gist-id-here

# GitHub Gist ID for .zshrc and zsh settings
GIST_ID_ZSHRC=your-gist-id-here

# File Paths

# VSCode snippets directory
# macOS default: $HOME/Library/Application Support/Code/User/snippets
SNIPPETS_DIR=$HOME/Library/Application Support/Code/User/snippets

# Zsh configuration file location
ZSHRC_PATH=$HOME/.zshrc

# Zsh settings directory (contains individual settings files)
ZSH_SETTINGS_DIR=$HOME/.zsh-settings
